PORT=8000
HOST=0.0.0.0
DERIBIT_ENV=testnet
DERIBIT_PAPER=true
DERIBIT_CLIENT_ID=your_client_id_here
DERIBIT_CLIENT_SECRET=your_client_secret_here
QUOTE_CACHE_TTL_MS=4000
QUOTE_CACHE_STALE_MS=20000
QUOTE_CACHE_HARD_MS=120000
AUDIT_LOG_PATH=./logs/audit.log
RISK_CONTROLS_PATH=./configs/risk_controls.json
PILOT_API_ENABLED=false
PILOT_VENUE_MODE=mock_falconx
POSTGRES_URL=postgresql://atticus:atticus@localhost:5432/atticus
PILOT_ADMIN_TOKEN=change_me
PILOT_ADMIN_IP_ALLOWLIST=127.0.0.1
PILOT_PROOF_TOKEN=change_me_proof_token
PILOT_MAX_PROTECTION_NOTIONAL_USDC=50000
PILOT_MAX_DAILY_PROTECTED_NOTIONAL_USDC=50000
USER_HASH_VERSION=1
USER_HASH_SECRET=change_me_hash_secret
PRICE_REFERENCE_MARKET_ID=BTC-USD
PRICE_REFERENCE_URL=https://api.exchange.coinbase.com/products/BTC-USD/ticker
PRICE_SINGLE_SOURCE=true
FALLBACK_PRICE_URL=
PRICE_TIMEOUT_PRIMARY_MS=800
PRICE_TIMEOUT_FALLBACK_MS=800
PRICE_FRESHNESS_MAX_MS=5000
EXPIRY_PRICE_INITIAL_WINDOW_MS=5000
EXPIRY_RETRY_INTERVAL_MS=30000
REQUIRE_FULL_POSITION_COVERAGE=true
REQUIRE_FULL_EXECUTION_FILL=true
FULL_COVERAGE_TOLERANCE_PCT=0.005
PILOT_ENDPOINT_VERSION=v1
FALCONX_BASE_URL=https://api.falconx.io
FALCONX_API_KEY=your_falconx_api_key
FALCONX_SECRET=your_falconx_secret_base64
FALCONX_PASSPHRASE=your_falconx_passphrase