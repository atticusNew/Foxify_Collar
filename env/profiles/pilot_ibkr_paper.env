# Phase 3A profile: IBKR CME paper rehearsal
# Usage: cp env/profiles/pilot_ibkr_paper.env .env

PILOT_API_ENABLED=true
PILOT_VENUE_MODE=ibkr_cme_paper
PILOT_HEDGE_POLICY=options_only_native
PILOT_TENOR_MIN_DAYS=1
PILOT_TENOR_MAX_DAYS=30
PILOT_TENOR_DEFAULT_DAYS=14
PILOT_TENOR_CANDIDATES=3,7,14,21,30
PILOT_VENUE_QUOTE_TIMEOUT_MS=30000
PILOT_QUOTE_TTL_MS=30000
PILOT_VENUE_EXEC_TIMEOUT_MS=12000
PILOT_VENUE_MARK_TIMEOUT_MS=3000
PILOT_ADMIN_TOKEN=change_me_admin_token
PILOT_INTERNAL_TOKEN=change_me_internal_token
PILOT_PROOF_TOKEN=change_me_proof_token
PILOT_ADMIN_IP_ALLOWLIST=127.0.0.1
PILOT_TRUST_PROXY=false
USER_HASH_SECRET=change_me_user_hash_secret

PRICE_SINGLE_SOURCE=true
PRICE_REFERENCE_URL=https://api.exchange.coinbase.com/products/BTC-USD/ticker
PRICE_REFERENCE_MARKET_ID=BTC-USD
PRICE_REQUEST_RETRY_ATTEMPTS=2
PRICE_REQUEST_RETRY_DELAY_MS=120
PRICE_TIMEOUT_PRIMARY_MS=2500
PRICE_FRESHNESS_MAX_MS=30000

POSTGRES_URL=postgresql://atticus:change_me_db_password@postgres:5432/atticus
DB_PASSWORD=change_me_db_password

IBKR_BRIDGE_BASE_URL=http://broker-bridge:18080
IBKR_BRIDGE_TOKEN=change_me_bridge_token
IBKR_BRIDGE_TIMEOUT_MS=4000
IBKR_ACCOUNT_ID=DU123456
IBKR_ENABLE_EXECUTION=false
IBKR_REQUIRE_LIVE_TRANSPORT=false
IBKR_ORDER_TIMEOUT_MS=8000
IBKR_MAX_REPRICE_STEPS=4
IBKR_REPRICE_STEP_TICKS=2
IBKR_MAX_SLIPPAGE_BPS=25
IBKR_ORDER_TIF=IOC
IBKR_PRIMARY_PRODUCT_FAMILY=MBT
IBKR_BFF_FALLBACK_ENABLED=false
IBKR_BFF_PRODUCT_FAMILY=BFF
IBKR_MAX_TENOR_DRIFT_DAYS=10
IBKR_PREFER_TENOR_AT_OR_ABOVE=true
IBKR_OPTION_LIQUIDITY_SELECTION_ENABLED=true
IBKR_OPTION_LIQUIDITY_TENOR_WINDOW_DAYS=4
IBKR_OPTION_PROBE_PARALLELISM=3
IBKR_OPTION_PROTECTION_TOLERANCE_PCT=0.03
IBKR_MAX_OPTION_PREMIUM_RATIO=0.20

IBKR_BRIDGE_PORT=18080
IBKR_BRIDGE_HOST=0.0.0.0
IBKR_BRIDGE_REQUIRE_AUTH=true
IBKR_BRIDGE_READONLY=false
IBKR_BRIDGE_TRANSPORT=ib_socket
IBKR_BRIDGE_FALLBACK_TO_SYNTHETIC=true
IBKR_GATEWAY_HOST=host.docker.internal
IBKR_GATEWAY_PORT=14002
IBKR_GATEWAY_CLIENT_ID=101
IBKR_GATEWAY_CONNECT_TIMEOUT_MS=5000
IBKR_GATEWAY_REQUEST_TIMEOUT_MS=6000
IBKR_MARKET_DATA_TYPE=1
