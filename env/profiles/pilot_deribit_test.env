# Pilot profile: Deribit test fallback/dev only (not canonical live path)
NODE_ENV=production
PILOT_API_ENABLED=true
PILOT_VENUE_MODE=deribit_test
PILOT_FORCE_DERIBIT_TEST_MODE=true
PILOT_HEDGE_POLICY=options_primary_futures_fallback

# API + DB
PORT=8000
HOST=0.0.0.0
POSTGRES_URL=postgresql://atticus:<DB_PASSWORD>@postgres:5432/atticus
DB_PASSWORD=<DB_PASSWORD>

# Canonical reference feed
PRICE_SINGLE_SOURCE=true
PRICE_REFERENCE_URL=https://api.exchange.coinbase.com/products/BTC-USD/ticker
PRICE_REFERENCE_MARKET_ID=BTC-USD

# Pilot controls
PILOT_TENANT_SCOPE_ID=foxify-pilot
PILOT_TERMS_VERSION=v1.0
USER_HASH_SECRET=<LONG_RANDOM_SECRET>
PILOT_ADMIN_TOKEN=<LONG_RANDOM_SECRET>
PILOT_INTERNAL_TOKEN=<LONG_RANDOM_SECRET>
PILOT_PROOF_TOKEN=<LONG_RANDOM_SECRET>
PILOT_ADMIN_IP_ALLOWLIST=127.0.0.1

PILOT_VENUE_QUOTE_TIMEOUT_MS=30000
PILOT_VENUE_EXEC_TIMEOUT_MS=15000
PILOT_VENUE_MARK_TIMEOUT_MS=4000
PILOT_QUOTE_TTL_MS=30000

PILOT_TENOR_MIN_DAYS=1
PILOT_TENOR_MAX_DAYS=30
PILOT_TENOR_DEFAULT_DAYS=14
PILOT_TENOR_CANDIDATES=3,7,14,21,30

# Deribit
DERIBIT_ENV=testnet
DERIBIT_PAPER=true
DERIBIT_CLIENT_ID=<DERIBIT_CLIENT_ID>
DERIBIT_CLIENT_SECRET=<DERIBIT_CLIENT_SECRET>
PILOT_DERIBIT_QUOTE_POLICY=ask_or_mark_fallback
PILOT_STRIKE_SELECTION_MODE=trigger_aligned
PILOT_DERIBIT_MAX_TENOR_DRIFT_DAYS=3

# Explicitly disable IBKR-specific path
IBKR_BRIDGE_BASE_URL=http://broker-bridge:18080
IBKR_BRIDGE_TIMEOUT_MS=4000
IBKR_BRIDGE_TOKEN=
IBKR_ACCOUNT_ID=
IBKR_ENABLE_EXECUTION=false
IBKR_REQUIRE_LIVE_TRANSPORT=false
IBKR_BRIDGE_REQUIRE_AUTH=true
IBKR_BRIDGE_READONLY=true
IBKR_BRIDGE_TRANSPORT=synthetic
IBKR_BRIDGE_FALLBACK_TO_SYNTHETIC=true
