{
  "name": "foxify_collar",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "dev:api": "npm --workspace services/api run dev",
    "lint": "npm run type-check",
    "type-check": "npm --workspace services/api exec tsc --noEmit && npm --workspace apps/web exec tsc --noEmit",
    "test:unit": "npm --workspace services/api test && npm --workspace services/hedging run test",
    "test:integration": "npm --workspace services/api test",
    "test:coverage": "npm --workspace services/api test",
    "build": "npm run build:web",
    "test:smoke": "npm --workspace apps/web run build",
    "test": "npm --workspace services/hedging run test"
  }
}
